# ============================================================
# RecoverLab CRM — Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recoverlab_crm
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET_KEY_HERE
JWT_EXPIRES_IN=8h

# CORS
FRONTEND_URL=http://localhost:5173

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

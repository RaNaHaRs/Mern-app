# ============================================================
# RecoverLab CRM — Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# Server
PORT=5001
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recoverlab_crm
DB_USER=postgres
DB_PASSWORD=Harsh@2607
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT
JWT_SECRET=RecoverLabCRM2024SecretKey!XyZ9@mNpQrStUvWxAbCdEfGhIjKlMnOpQrS
JWT_EXPIRES_IN=8h

# CORS
FRONTEND_URL=http://localhost:5173

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ============================================================
# RAZORPAY (Payment Gateway)
# ============================================================
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ============================================================
# EMAIL / SMTP (Nodemailer — for invoice emails)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=billing@recoverlab.in
SMTP_FROM_NAME=RecoverLab Billing

# ============================================================
# INVOICE SETTINGS
# ============================================================
INVOICE_PREFIX=RCL-INV
APP_NAME=RecoverLab
